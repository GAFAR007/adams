# Core server
NODE_ENV=development
HOST=127.0.0.1
PORT=4000
MONGODB_URI=mongodb://127.0.0.1:27017/adams

# Auth
JWT_ACCESS_SECRET=replace-with-a-secure-access-secret
JWT_REFRESH_SECRET=replace-with-a-secure-refresh-secret
JWT_INVITE_SECRET=replace-with-a-secure-invite-secret
JWT_CUSTOMER_REGISTRATION_SECRET=replace-with-a-secure-customer-registration-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
CUSTOMER_REGISTRATION_CODE_TTL_MINUTES=15
CUSTOMER_REGISTRATION_VERIFICATION_TOKEN_TTL=30m
STAFF_INVITE_TTL_HOURS=72

# Frontend origins
CORS_ORIGIN=http://127.0.0.1:5173,http://localhost:5173,http://localhost:8080,http://localhost:3000
FRONTEND_APP_URL=http://localhost:5173

# Rate limiting
AUTH_RATE_LIMIT_MAX_ATTEMPTS=10
AUTH_RATE_LIMIT_WINDOW_MS=60000

# Seeded local/demo users
SEED_ADMIN_FIRST_NAME=Adams
SEED_ADMIN_LAST_NAME=Gafar
SEED_ADMIN_PASSWORD=AdminPass123!
SEED_STAFF_PASSWORD=StaffPass123!
SEED_CUSTOMER_PASSWORD=CustomerPass123!

# Email
EMAIL_PROVIDER=
BREVO_API_KEY=
EMAIL_FROM=
EMAIL_FROM_NAME=Adams

# File storage
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Address validation
GOOGLE_ADDRESS_API_KEY=

# AI provider
AI_PROVIDER=groq
AI_API_KEY=
AI_BASE_URL=https://api.groq.com/openai/v1
AI_MODEL_DEFAULT=llama-3.1-8b-instant
AI_MODEL_REASONING=llama-3.1-70b-versatile

# Payments
STRIPE_SECRET_KEY=
STRIPE_SUCCESS_URL=http://localhost:5173/#/app/requests
STRIPE_CANCEL_URL=http://localhost:5173/#/app/requests
